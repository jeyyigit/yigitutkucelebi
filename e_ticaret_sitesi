class Urun:     def __init__(self, isim, fiyat, stok):         self.isim = isim         self.fiyat = fiyat         self.stok = stok 
 class Sepet:     def __init__(self):         self.urunler = {} 
     def urun_ekle(self, urun, adet): 
        if urun.stok >= adet:             if urun in self.urunler: 
                self.urunler[urun] += adet             else: 
                self.urunler[urun] = adet             urun.stok -= adet         else: 
            print("Stok yetersiz") 
     def urun_sil(self, urun):         if urun in self.urunler:             adet = self.urunler[urun]             urun.stok += adet             del self.urunler[urun] 
     def toplam_tutar(self): 
        toplam = 0         for urun, adet in self.urunler.items(): 
            toplam += urun.fiyat * adet         return toplam 
