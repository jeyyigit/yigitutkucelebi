class BankaHesabi:
    def __init__(self, isim, bakiye=0):
        self.isim = isim
        self.bakiye = bakiye
        self.hareket_gecmisi = []

    def _islem_kaydet(self, *args):
        mesaj = " | ".join(str(arg) for arg in args)
        self.hareket_gecmisi.append(mesaj)

    def para_yatir(self, miktar):
        if miktar > 0:
            self.bakiye += miktar
            self._islem_kaydet("Para Yatırma", miktar, f"Güncel: {self.bakiye}")

    def para_cek(self, miktar):
        if miktar > 0 and self.bakiye >= miktar:
            self.bakiye -= miktar
            self._islem_kaydet("Para Çekme", miktar, f"Güncel: {self.bakiye}")

    def ozet(self):
        for hareket in self.hareket_gecmisi:
            print(hareket)
